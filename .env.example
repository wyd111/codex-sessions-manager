# Preferred: one or more Codex homes/session roots to show in the UI.
# Use forward slashes in Windows paths to avoid escaping backslashes in JSON.
# Example for a Windows API-key Codex home:
# CODEX_SESSION_SOURCES='[{"id":"default-apikey","name":"Default API Key","codexHome":"C:/Users/<WindowsUser>/.codex"}]'
#
# Future example with separate ChatGPT login home:
# CODEX_SESSION_SOURCES='[{"id":"default-apikey","name":"Default API Key","codexHome":"C:/Users/<WindowsUser>/.codex"},{"id":"chatgpt","name":"ChatGPT Login","codexHome":"C:/Users/<WindowsUser>/.codex-chatgpt"}]'

# Backward-compatible single sessions directory path (inside WSL or host).
# Used only when CODEX_SESSION_SOURCES is not set.
SESSIONS_ROOT_PATH="/home/<user>/.codex/sessions"

# Vite dev/preview binding
VITE_HOST="0.0.0.0"
VITE_PORT="5172"
